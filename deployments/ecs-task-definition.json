{
  "family": "rategate",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::380278405578:role/rategate-task-execution-role",
  "containerDefinitions": [
    {
      "name": "rategate",
      "image": "380278405578.dkr.ecr.us-east-1.amazonaws.com/rategate:latest",
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "REDIS_TLS",
          "value": "true"
        }
      ],
      "secrets": [
        {
          "name": "REDIS_ADDR",
          "valueFrom": "arn:aws:ssm:us-east-1:380278405578:parameter/rategate/prod/redis/addr"
        },
        {
          "name": "REDIS_PASSWORD",
          "valueFrom": "arn:aws:ssm:us-east-1:380278405578:parameter/rategate/prod/redis/password"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:8080/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 10
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/rategate",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
